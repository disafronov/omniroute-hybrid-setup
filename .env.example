# Local API key — used by both docker compose (mapped to OMNIROUTE_API_KEY) and main.py
LOCAL_API_KEY=sk-your-local-key-here
# Upstream cloud OmniRoute API key
CLOUD_API_KEY=sk-your-cloud-key-here
# Upstream cloud OmniRoute base URL
CLOUD_BASE_URL=https://omniroute.hostname.tld/v1
# Local OmniRoute base URL (optional, default: http://127.0.0.1:20128)
LOCAL_BASE_URL=http://127.0.0.1:20128
# Ollama endpoint (optional, default: http://host.docker.internal:11434/v1)
LOCAL_OLLAMA_URL=http://host.docker.internal:11434/v1
# Local ollama models for each combo (optional, defaults below)
LOCAL_CODING=qwen2.5-coder:14b
LOCAL_FAST=qwen2.5:7b
LOCAL_REASONING=deepseek-r1:14b
